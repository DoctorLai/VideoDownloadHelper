{
  "name": "simple-video-download-helper",
  "version": "3.2.1",
  "private": true,
  "description": "Browser extension that helps you find and download videos from supported websites.",
  "directories": {
    "test": "test"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "adm-zip": "^0.6.0",
    "chai": "^6.2.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "prettier": "^3.9.5",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "scripts": {
    "test": "mocha",
    "coverage": "nyc mocha",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check && npm run coverage && npm run build",
    "dev": "webpack --mode development",
    "build": "webpack --mode production",
    "watch": "webpack --watch",
    "package": "npm run build && node scripts/package.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoctorLai/VideoDownloadHelper"
  },
  "keywords": [
    "video",
    "download video",
    "video url",
    "save video",
    "chrome extension",
    "browser extension"
  ],
  "author": "justyy <dr.zhihua.lai@gmail.com> (https://helloacm.com)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/DoctorLai/VideoDownloadHelper/issues"
  },
  "homepage": "https://chrome.google.com/webstore/detail/simple-video-download-hel/ilcdiicigjaccgipndigcenjieedjohj"
}
